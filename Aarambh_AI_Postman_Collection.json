                  "if (json.id) { pm.collectionVariables.set('CHILD_ID', json.id); pm.collectionVariables.set('AWC_ID', json.awc_id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Aasha Bai\",\n  \"date_of_birth\": \"2020-06-15\",\n  \"gender\": \"FEMALE\",\n  \"awc_id\": 1,\n  \"parent_name\": \"Suman Bai\",\n  \"parent_phone\": \"+919876543211\",\n  \"parent_language\": \"hi\",\n  \"notes\": \"Registered at Sedam AWC-001\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/children/",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "children",
                ""
