# === AARAMBH AI — Environment Variables ===

# PostgreSQL Database (set automatically by Replit DB addon)
DATABASE_URL=postgresql://user:password@localhost:5432/aarambh_db

# JWT Authentication
JWT_SECRET=your-very-long-random-secret-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# OpenAI (for Whisper, GPT-4o NLP, Drawing Analysis, DDT Synthesis)
OPENAI_API_KEY=sk-proj-...

# App Config
FRONTEND_URL=http://localhost:3000
UPLOAD_DIR=/tmp/uploads
MAX_FILE_SIZE_MB=10
DEBUG=true

# Optional: WhatsApp Business API
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Optional: SMS for real OTP (Twilio / MSG91)
SMS_API_KEY=
SMS_FROM_NUMBER=
